generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("SUPABASE_DB_URL")
}

enum Role {
  CITIZEN
  OPERATOR
  DEPARTMENT_ADMIN
  FIELD_WORKER
  CITY_SUPERVISOR
  SUPERADMIN
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  DONE
  REJECTED
}

model Department {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  description String?
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       User[]
  categories  TicketCategory[]
  tickets     Ticket[]

  @@map("departments")
}

model User {
  id             String              @id @default(uuid())
  name           String              @unique
  firstName      String?             @map("first_name")
  surname        String?
  email          String              @unique
  phoneNumber    String?             @map("phone_number")
  address        String?
  role           Role
  departmentId   String?             @map("department_id")
  passwordHash   String              @map("password_hash")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  department     Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  tickets        Ticket[]            @relation("TicketCreator")
  comments       TicketComment[]
  auditLogs      AuditLog[]
  statusChanges  TicketStatusHistory[]
  attachments    TicketAttachment[]

  @@index([departmentId])
  @@map("users")
}

model TicketCategory {
  id           String      @id @default(uuid())
  code         String      @unique
  name         String
  description  String?
  departmentId String      @map("department_id")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  department   Department  @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  tickets      Ticket[]

  @@index([departmentId])
  @@map("ticket_categories")
}

model Ticket {
  id                   String                @id @default(uuid())
  title                String
  description          String?
  status               TicketStatus          @default(NEW)
  latitude             Float
  longitude            Float
  h3Index              String                @map("h3_index")
  createdById          String                @map("created_by")
  assignedDepartmentId String?               @map("assigned_department_id")
  categoryId           String                @map("category_id")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  resolvedAt           DateTime?             @map("resolved_at")
  createdBy            User                  @relation("TicketCreator", fields: [createdById], references: [id], onDelete: Cascade)
  assignedDepartment   Department?           @relation(fields: [assignedDepartmentId], references: [id], onDelete: SetNull)
  category             TicketCategory        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  comments             TicketComment[]
  attachments          TicketAttachment[]
  statusHistory        TicketStatusHistory[]

  @@index([createdById])
  @@index([assignedDepartmentId])
  @@index([categoryId])
  @@index([h3Index])
  @@map("tickets")
}

model TicketComment {
  id          String   @id @default(uuid())
  ticketId    String   @map("ticket_id")
  authorUserId String  @map("author_user_id")
  message     String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([authorUserId])
  @@map("ticket_comments")
}

model TicketAttachment {
  id          String   @id @default(uuid())
  ticketId    String   @map("ticket_id")
  storagePath String   @map("storage_path")
  mimeType    String?  @map("mime_type")
  size        Int?
  uploadedById String? @map("uploaded_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy  User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([uploadedById])
  @@map("ticket_attachments")
}

model TicketStatusHistory {
  id            String       @id @default(uuid())
  ticketId      String       @map("ticket_id")
  fromStatus    TicketStatus? @map("from_status")
  toStatus      TicketStatus @map("to_status")
  changedById   String       @map("changed_by_id")
  comment       String?
  createdAt     DateTime     @default(now()) @map("created_at")
  ticket        Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedBy     User         @relation(fields: [changedById], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([changedById])
  @@map("ticket_status_history")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  timestamp  DateTime @default(now())
  meta       Json?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@map("audit_logs")
}

model H3Aggregate {
  h3Index     String   @map("h3_index")
  date        String
  ticketCount Int      @default(0) @map("ticket_count")

  @@id([h3Index, date])
  @@map("h3_aggregates")
}
